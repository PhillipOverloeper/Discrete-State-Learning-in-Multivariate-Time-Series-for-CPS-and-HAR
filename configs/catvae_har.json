{
  "seed": 42,

  "model": {
    "categorical_dim": 2,
    "beta": 0.25,
    "temperature": 1.0,
    "enc_hidden": [256, 128],
    "dec_hidden": [128, 256],
    "dropout": 0.0
  },

  "train": {
    "epochs": 200,
    "batch_size": 32,
    "lr": 0.005,
    "weight_decay": 0.0,
    "grad_clip_norm": 0.0,

    "early_stop_patience": 15,

    "ckpt_dir": "checkpoints/catvae/har",
    "ckpt_name": "catvae_best.pt"
  }
}
