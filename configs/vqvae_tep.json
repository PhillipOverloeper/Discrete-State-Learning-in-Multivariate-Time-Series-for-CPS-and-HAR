{
  "seed": 42,

  "model": {
    "latent_dim": 32,
    "num_embeddings": 28,
    "beta": 0.25,
    "enc_hidden": [256, 128],
    "dec_hidden": [128, 256],
    "dropout": 0.0
  },

  "train": {
    "epochs": 10,
    "batch_size": 32,
    "lr": 0.0002,
    "weight_decay": 0.0,
    "grad_clip_norm": 0.0,

    "recon_loss_type": "mse",
    "recon_weight": 1.0,
    "vq_weight": 1.0,

    "early_stop_patience": 15,

    "ckpt_dir": "checkpoints/vqvae/tep",
    "ckpt_name": "vqvae_best.pt"
  }
}
