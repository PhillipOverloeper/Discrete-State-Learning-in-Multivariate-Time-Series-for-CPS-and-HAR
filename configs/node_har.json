{
  "seed": 42,

  "model": {
    "emb_dim": 32,
    "latent_dim": 32,
    "K": 4,
    "lambda_ent": 0.25,
    "lambda_smooth": 0.25,
    "ode_hidden": 16,
    "enc_hidden": [256, 128],
    "dec_hidden": [128, 256],
    "dropout": 0.0
  },

  "train": {
    "epochs": 20,
    "batch_size": 32,
    "lr": 0.005,
    "weight_decay": 0.0,
    "grad_clip_norm": 0.0,

    "early_stop_patience": 15,

    "ckpt_dir": "checkpoints/node/har",
    "ckpt_name": "node_best.pt"
  }
}
